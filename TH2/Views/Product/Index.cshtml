@model IEnumerable<TH2.Models.Product>

@{
    ViewData["Title"] = "Showroom Siêu Xe";
}

<style>
    body {
        background-image: url('/images/hinh-nen-may-tinh-4k-dep (66).jpg');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        background-repeat: no-repeat;
    }

    .product-card {
        background-color: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: 1px solid rgba(255,255,255,0.5);
    }

        .product-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.4) !important;
            border-color: #e5c158; /* Viền sáng lên màu vàng khi hover */
        }

    .product-img-container {
        height: 240px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        padding: 15px;
        background-color: rgba(0,0,0,0.02);
        border-bottom: 1px solid #f0f0f0;
    }

    .product-img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        transition: 0.5s;
    }

    .product-card:hover .product-img {
        transform: scale(1.08); /* Phóng to ảnh xe nhẹ khi rê chuột */
    }

    .text-truncate-2-lines {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .price-tag {
        color: #d90429;
        font-weight: 900;
        font-size: 1.3rem;
    }
</style>

<div class="container mt-5 mb-5">
    <div class="text-center mb-5">
        <h2 class="text-warning fw-bold d-inline-block px-5 py-3 rounded-pill shadow" style="background-color: rgba(0, 0, 0, 0.8); text-transform: uppercase; letter-spacing: 2px;">
            <i class="bi bi-car-front-fill me-2"></i> Bộ Sưu Tập Siêu Xe
        </h2>
    </div>

    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var product in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm product-card rounded-4">

                    <div class="product-img-container rounded-top-4">
                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                        {
                            <img src="@product.ImageUrl" alt="@product.Name" class="product-img" />
                        }
                        else
                        {
                            <div class="text-muted d-flex flex-column align-items-center">
                                <i class="bi bi-camera fs-1"></i>
                                <span>Chưa cập nhật ảnh</span>
                            </div>
                        }
                    </div>

                    <div class="card-body d-flex flex-column p-4">
                        <h5 class="card-title fw-bold text-dark text-truncate" title="@product.Name" style="font-size: 1.2rem;">@product.Name</h5>
                        <div class="price-tag mb-3">@product.Price.ToString("#,##0") ₫</div>

                        <p class="card-text text-muted small flex-grow-1 text-truncate-2-lines" style="line-height: 1.6;">
                            @product.Description
                        </p>
                    </div>

                    <div class="card-footer bg-transparent border-top-0 pt-0 pb-4 px-4 text-center">
                        <div class="d-grid gap-2">
                            <a asp-controller="ShoppingCart" asp-action="AddToCart" asp-route-id="@product.Id" class="btn btn-warning fw-bold shadow-sm rounded-pill text-dark">
                                <i class="bi bi-cart-plus-fill me-1"></i> Đặt Mua Ngay
                            </a>
                            <a asp-action="Display" asp-route-id="@product.Id" class="btn btn-outline-dark fw-bold rounded-pill">
                                Xem Chi Tiết
                            </a>
                        </div>
                    </div>

                </div>
            </div>
        }
    </div>
</div>