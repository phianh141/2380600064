@model IEnumerable<TH2.Models.Product>

@{
    ViewData["Title"] = "Danh sách sản phẩm";
}

<style>
    /* 1. ĐOẠN NÀY LÀM HÌNH NỀN CHO TOÀN BỘ TRANG */
    body {
        /* NHỚ THAY 'hinh-nen-cua-ban.jpg' BẰNG ĐÚNG TÊN HÌNH BẠN MUỐN NHA */
        background-image: url('/images/hinh-nen-may-tinh-4k-dep (66).jpg');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        background-repeat: no-repeat;
    }

    /* 2. CSS CHO CÁC THẺ SẢN PHẨM (CARD) */
    .product-card {
        background-color: rgba(255, 255, 255, 0.85); /* Nền trắng hơi trong suốt để nhìn xuyên thấu nhẹ */
        backdrop-filter: blur(5px); /* Làm mờ phần nền bên dưới thẻ */
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        /* Hiệu ứng nhấc sản phẩm lên khi rê chuột vào */
        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 25px rgba(0,0,0,0.3) !important;
        }

    .product-img-container {
        height: 220px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        padding: 10px;
    }

    .product-img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
    }

    /* Giới hạn số dòng mô tả để thẻ không bị quá dài */
    .text-truncate-2-lines {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white fw-bold px-4 py-2 rounded shadow-sm" style="background-color: rgba(0, 0, 0, 0.6);">
            Sản Phẩm Của Cửa Hàng
        </h2>

        <a asp-action="Add" class="btn btn-success btn-lg shadow">
            <i class="bi bi-plus-lg"></i>Thêm Sản Phẩm Mới
        </a>
    </div>

    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var product in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 product-card rounded-4">

                    <div class="product-img-container">
                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                        {
                            <img src="@product.ImageUrl" alt="@product.Name" class="product-img rounded" />
                        }
                        else
                        {
                            <div class="text-muted d-flex flex-column align-items-center">
                                <span style="font-size: 2rem;">📷</span>
                                <span>Chưa có ảnh</span>
                            </div>
                        }
                    </div>

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold text-dark text-truncate" title="@product.Name">@product.Name</h5>
                        <h5 class="text-danger fw-bold mb-3">@product.Price VNĐ</h5>

                        <p class="card-text text-muted small flex-grow-1 text-truncate-2-lines">
                            @product.Description
                        </p>
                    </div>

                    <div class="card-footer bg-transparent border-top-0 pt-0 pb-3 text-center">
                        <div class="btn-group w-100 shadow-sm" role="group">
                            <a asp-action="Display" asp-route-id="@product.Id" class="btn btn-outline-primary btn-sm fw-bold">Xem</a>
                            <a asp-action="Update" asp-route-id="@product.Id" class="btn btn-outline-warning btn-sm fw-bold">Sửa</a>
                            <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-outline-danger btn-sm fw-bold">Xóa</a>
                        </div>
                    </div>

                </div>
            </div>
        }
    </div>
</div>