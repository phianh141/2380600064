@model IEnumerable<TH2.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng của bạn";
}

<style>
    /* 1. Bê nguyên ảnh nền xịn xò từ trang chi tiết sản phẩm qua */
    body {
        background-image: url('/images/hinh-nen-may-tinh-4k-dep (66).jpg');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
    }

    /* 2. Đồng bộ hiệu ứng kính mờ (giống hệt class .display-card) */
    .cart-wrapper {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    /* 3. Làm trong suốt nhẹ các thẻ con để không bị "đục" nền */
    .inner-card {
        background: rgba(255, 255, 255, 0.6) !important;
        border: 1px solid rgba(255, 255, 255, 0.8) !important;
    }

    .cart-item-img {
        width: 100%;
        max-width: 100px;
        height: 100px;
        object-fit: contain;
        border-radius: 12px;
        background-color: #fff; /* Đổi nền ảnh thành trắng tinh cho sản phẩm nổi bật */
        padding: 5px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    .btn-checkout {
        background: linear-gradient(to right, #ff416c, #ff4b2b);
        border: none;
    }

        .btn-checkout:hover {
            background: linear-gradient(to right, #ff4b2b, #ff416c);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 75, 43, 0.4);
            transition: 0.3s;
        }
</style>

<div class="cart-wrapper mt-5 mb-5 container">

    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25">
        <h2 class="fw-bold text-primary mb-0">
            <i class="bi bi-cart-check me-2"></i>Giỏ hàng của bạn
        </h2>
        <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary fw-bold shadow-sm bg-white" style="border-radius: 10px;">
            <i class="bi bi-arrow-left me-1"></i> Tiếp tục mua sắm
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow-sm mb-4 inner-card" style="border-radius: 15px;">
                    <div class="card-body p-4">
                        @foreach (var item in Model)
                        {
                            <div class="row align-items-center mb-4 pb-4 border-bottom border-secondary border-opacity-25">
                                <div class="col-md-2 col-4 text-center">
                                    <img src="@item.ImageUrl" alt="@item.Name" class="cart-item-img">
                                </div>

                                <div class="col-md-4 col-8">
                                    <h5 class="fw-bold mb-2 text-dark">@item.Name</h5>
                                    <p class="text-muted mb-0">Đơn giá: <span class="fw-bold text-danger">@item.Price.ToString("#,##0") đ</span></p>
                                </div>

                                <div class="col-md-3 col-6 mt-3 mt-md-0">
                                    <div class="d-flex align-items-center justify-content-md-center">
                                        <span class="me-2 text-muted fw-bold">SL:</span>
                                        <input type="number" class="form-control text-center shadow-none border-0 fw-bold"
                                               value="@item.Quantity" min="1" readonly style="width: 70px; border-radius: 10px; background-color: rgba(255,255,255,0.8);">
                                    </div>
                                </div>

                                <div class="col-md-2 col-4 mt-3 mt-md-0 text-end text-md-center">
                                    <h6 class="fw-bold text-danger mb-0 fs-5">@item.Total.ToString("#,##0") đ</h6>
                                </div>

                                <div class="col-md-1 col-2 mt-3 mt-md-0 text-end">
                                    <a asp-controller="ShoppingCart" asp-action="RemoveFromCart" asp-route-id="@item.ProductId"
                                       class="btn btn-danger btn-sm rounded-circle shadow-sm" style="width: 35px; height: 35px; padding-top: 5px;" title="Xóa khỏi giỏ">
                                        <i class="bi bi-trash3-fill"></i>
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-4 mt-4 mt-lg-0">
                <div class="card shadow-sm p-4 inner-card" style="border-radius: 15px; position: sticky; top: 100px;">
                    <h4 class="fw-bold mb-4 text-dark">Tóm tắt đơn hàng</h4>

                    <div class="d-flex justify-content-between mb-3 text-dark">
                        <span class="fw-semibold">Tổng tiền hàng:</span>
                        <span class="fw-bold">@Model.Sum(m => m.Total).ToString("#,##0") đ</span>
                    </div>

                    <div class="d-flex justify-content-between mb-3 text-dark">
                        <span class="fw-semibold">Phí vận chuyển:</span>
                        <span class="text-success fw-bold">Miễn phí</span>
                    </div>

                    <hr class="my-4 border-secondary border-opacity-25">

                    <div class="d-flex justify-content-between mb-4">
                        <span class="fw-bold fs-5 text-dark">Tổng cộng:</span>
                        <span class="fw-bold fs-4 text-danger">@Model.Sum(m => m.Total).ToString("#,##0") đ</span>
                    </div>

                    <a href="#" class="btn btn-checkout btn-lg w-100 rounded-pill fw-bold text-white shadow">
                        <i class="bi bi-credit-card me-2"></i>Thanh toán ngay
                    </a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 my-5 inner-card shadow-sm" style="border-radius: 20px;">
            <i class="bi bi-cart-x text-muted" style="font-size: 6rem; opacity: 0.5;"></i>
            <h3 class="mt-4 fw-bold text-dark">Giỏ hàng của bạn đang trống</h3>
            <p class="text-dark fs-5">Hãy chọn thêm vài món đồ ưng ý vào giỏ hàng nhé!</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg rounded-pill mt-3 px-5 shadow-sm fw-bold">
                <i class="bi bi-bag-heart me-2"></i>Mua sắm ngay
            </a>
        </div>
    }
</div>