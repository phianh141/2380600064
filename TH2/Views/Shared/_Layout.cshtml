@using TH2.Extensions
@using TH2.Models

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PhiAnh Motors</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TH2.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        /* TRIỆT TIÊU KHOẢNG HỞ MẶC ĐỊNH CỦA ASP.NET CORE */
        body {
            margin-bottom: 0 !important;
            padding-bottom: 0 !important;
        }

        /* Tùy chỉnh thanh Navbar bóng bẩy */
        .navbar-luxury {
            background-color: rgba(15, 15, 15, 0.95) !important;
            backdrop-filter: blur(10px);
            border-bottom: 2px solid #e5c158;
        }

        .navbar-brand {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            font-weight: 800;
            letter-spacing: 1px;
        }

        .nav-link {
            font-weight: 500;
            transition: 0.3s;
        }

            .nav-link:hover {
                color: #e5c158 !important;
            }

        /* Chỉnh giỏ hàng */
        .cart-icon-wrapper {
            transition: transform 0.2s;
        }

            .cart-icon-wrapper:hover {
                transform: scale(1.1);
            }
    </style>
</head>

<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark navbar-luxury box-shadow mb-0 sticky-top">
            <div class="container-fluid px-4">
                <a class="navbar-brand text-white" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-car-front-fill text-warning me-1"></i> PHIANH <span class="text-warning">MOTORS</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-4">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-controller="Home" asp-action="Index">Trang Chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-controller="Product" asp-action="Index">Siêu Xe</a>
                        </li>

                        @* --- NÚT TRANG QUẢN TRỊ CHỈ HIỆN KHI LÀ ADMIN --- *@
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item ms-lg-3">
                                <a class="nav-link text-dark bg-warning px-3 rounded-pill fw-bold" asp-area="Admin" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-gear-fill me-1"></i> Quản Trị
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        @* --- GIỎ HÀNG --- *@
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            var cart = Context.Session.GetJson<List<CartItem>>("Cart");
                            int totalQuantity = cart != null ? cart.Sum(c => c.Quantity) : 0;

                            <li class="nav-item me-3 cart-icon-wrapper">
                                <a asp-controller="ShoppingCart" asp-action="Index" class="nav-link position-relative text-white">
                                    <i class="bi bi-bag-fill fs-4"></i>
                                    @if (totalQuantity > 0)
                                    {
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-2 border-dark" style="font-size: 0.75rem; margin-top: 10px; margin-left: -8px;">
                                            @totalQuantity
                                        </span>
                                    }
                                </a>
                            </li>
                        }

                        @* --- MENU TÀI KHOẢN (DROPDOWN) --- *@
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center text-white" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle fs-4 me-2"></i>
                                @if (User.Identity != null && User.Identity.IsAuthenticated)
                                {
                                    <span class="d-none d-md-inline">@User.Identity.Name</span>
                                }
                                else
                                {
                                    <span class="d-none d-md-inline">Tài khoản</span>
                                }
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-2 rounded-3" aria-labelledby="userDropdown">
                                @if (User.Identity != null && User.Identity.IsAuthenticated)
                                {
                                    
                                    <li><a class="dropdown-item py-2" asp-area="Identity" asp-page="/Account/Manage/Index"><i class="bi bi-person-lines-fill me-2 text-muted"></i> Hồ sơ của tôi</a></li>
                                    <li><a class="dropdown-item py-2" asp-controller="Order" asp-action="History"><i class="bi bi-clock-history me-2 text-muted"></i> Lịch sử mua xe</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                            <button type="submit" class="dropdown-item py-2 text-danger fw-bold"><i class="bi bi-box-arrow-right me-2"></i> Đăng xuất</button>
                                        </form>
                                    </li>
                                }
                                else
                                {
                                    <li><a class="dropdown-item py-2" asp-area="Identity" asp-page="/Account/Login"><i class="bi bi-box-arrow-in-right me-2 text-primary"></i> Đăng nhập</a></li>
                                    <li><a class="dropdown-item py-2" asp-area="Identity" asp-page="/Account/Register"><i class="bi bi-person-plus me-2 text-success"></i> Đăng ký thành viên</a></li>
                                }
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid p-0 flex-grow-1">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="text-light py-3 mt-auto w-100" style="background-color: rgba(15, 15, 15, 0.7); backdrop-filter: blur(8px); border-top: 1px solid rgba(229, 193, 88, 0.3);">
        <div class="container text-center" style="font-size: 0.95rem;">
            &copy; 2026 - PhiAnh Motors - <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-warning text-decoration-none fw-bold">Chính sách bảo mật</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>