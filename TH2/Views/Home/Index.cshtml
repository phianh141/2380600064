@{
    ViewData["Title"] = "Trang Chủ";
}

<style>
    body {
        background-image: url('/images/hinh-nen-may-tinh-4k-dep (66).jpg');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        background-repeat: no-repeat;
    }

    .hero-banner {
        background-image: url('/images/mclaren-765lt-night-3840x2563-20401.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        border-radius: 20px;
        overflow: hidden;
        margin-top: 30px;
    }

    .hero-overlay {
        background-color: rgba(0, 0, 0, 0.65); /* Làm tối hơn xíu để chữ nổi bật */
        padding: 7rem 2rem;
    }

    /* Hiệu ứng kính mờ cho các thẻ thông tin */
    .glass-feature {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 15px;
        color: white;
        transition: 0.3s;
    }

        .glass-feature:hover {
            transform: translateY(-10px);
            background: rgba(255, 255, 255, 0.15);
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }
</style>

<div class="container">
    <div class="hero-banner shadow-lg">
        <div class="hero-overlay text-center">
            <h1 class="display-3 fw-bold text-warning mb-3" style="text-transform: uppercase; letter-spacing: 2px;">PhiAnh Motors</h1>
            <p class="col-md-8 mx-auto fs-4 text-light mb-5" style="line-height: 1.6;">
                Nơi thỏa mãn đam mê tốc độ. Chúng tôi mang đến những dòng siêu xe đẳng cấp, sang trọng và độc quyền nhất thế giới dành riêng cho bạn.
            </p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-warning btn-lg shadow-lg px-5 py-3 fw-bold rounded-pill text-dark">
                Khám Phá Bộ Sưu Tập Kỷ Nguyên Mới
            </a>
        </div>
    </div>

    <div class="row text-center mt-5 mb-5 pb-4">
        <div class="col-md-4 mb-4">
            <div class="card h-100 glass-feature p-4">
                <div class="card-body">
                    <h2 class="text-warning mb-3" style="font-size: 3.5rem;"><i class="bi bi-car-front-fill"></i></h2>
                    <h4 class="card-title fw-bold">Đẳng Cấp & Giới Hạn</h4>
                    <p class="card-text text-light opacity-75 mt-3">Sở hữu những kiệt tác siêu xe phiên bản giới hạn, khẳng định vị thế và phong cách sống của bạn.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 glass-feature p-4">
                <div class="card-body">
                    <h2 class="text-warning mb-3" style="font-size: 3.5rem;"><i class="bi bi-shield-check"></i></h2>
                    <h4 class="card-title fw-bold">Bảo Hành Toàn Cầu</h4>
                    <p class="card-text text-light opacity-75 mt-3">Chính sách hậu mãi chuẩn quốc tế. Chăm sóc và bảo dưỡng xe bởi các chuyên gia hàng đầu.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 glass-feature p-4">
                <div class="card-body">
                    <h2 class="text-warning mb-3" style="font-size: 3.5rem;"><i class="bi bi-headset"></i></h2>
                    <h4 class="card-title fw-bold">Hỗ Trợ Đặc Quyền 24/7</h4>
                    <p class="card-text text-light opacity-75 mt-3">Dịch vụ chăm sóc khách hàng VIP. Đội ngũ chuyên viên luôn sẵn sàng hỗ trợ bạn bất cứ lúc nào.</p>
                </div>
            </div>
        </div>
    </div>
</div>