@model TH2.Models.Order

@{
    ViewData["Title"] = "Chi Tiết Đơn Hàng";
}

<style>
    body {
        background-image: url('/images/hinh-nen-may-tinh-4k-dep (66).jpg');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .info-box {
        background: #f8f9fa;
        border-left: 5px solid #0d6efd;
        border-radius: 10px;
        padding: 20px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    }
</style>

<div class="container mt-5 mb-5 glass-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold m-0">
            <i class="bi bi-receipt"></i> Chi Tiết Đơn Hàng #@Model.Id
        </h2>
        <a asp-action="Index" class="btn btn-outline-secondary fw-bold px-4 shadow-sm">
            <i class="bi bi-arrow-left"></i> Quay Lại
        </a>
    </div>

    <div class="row mb-5">
        <div class="col-md-7">
            <div class="info-box h-100">
                <h5 class="fw-bold text-dark mb-3"><i class="bi bi-person-lines-fill text-primary"></i> Thông Tin Giao Hàng</h5>
                <p class="mb-2"><strong>Khách hàng:</strong> @Model.CustomerName</p>
                <p class="mb-2"><strong>Số điện thoại:</strong> @(string.IsNullOrEmpty(Model.PhoneNumber) ? "Chưa cung cấp" : Model.PhoneNumber)</p>
                <p class="mb-2"><strong>Địa chỉ giao:</strong> @(string.IsNullOrEmpty(Model.ShippingAddress) ? "Chưa cung cấp" : Model.ShippingAddress)</p>
                <p class="mb-0"><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
        </div>

        <div class="col-md-5">
            <div class="info-box border-left-warning h-100" style="border-left-color: #ffc107 !important;">
                <h5 class="fw-bold text-dark mb-3"><i class="bi bi-truck text-warning"></i> Trạng Thái Đơn Hàng</h5>

                <div class="mb-3 fs-5">
                    @if (Model.OrderStatus == "Pending")
                    {
                        <span class="badge bg-warning text-dark px-3 py-2">Chờ xử lý</span>
                    }
                    else if (Model.OrderStatus == "Shipping")
                    {
                        <span class="badge bg-info text-dark px-3 py-2">Đang giao</span>
                    }
                    else if (Model.OrderStatus == "Completed")
                    {
                        <span class="badge bg-success px-3 py-2">Hoàn thành</span>
                    }
                    else
                    {
                        <span class="badge bg-danger px-3 py-2">Đã hủy</span>
                    }
                </div>

                <form asp-action="UpdateStatus" method="post" class="d-flex gap-2">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <select name="newStatus" class="form-select shadow-sm">
                        <option value="Pending" selected="@(Model.OrderStatus == "Pending")">Chờ xử lý</option>
                        <option value="Shipping" selected="@(Model.OrderStatus == "Shipping")">Đang giao</option>
                        <option value="Completed" selected="@(Model.OrderStatus == "Completed")">Hoàn thành</option>
                        <option value="Cancelled" selected="@(Model.OrderStatus == "Cancelled")">Đã hủy</option>
                    </select>
                    <button type="submit" class="btn btn-warning fw-bold shadow-sm text-nowrap">Cập Nhật</button>
                </form>
            </div>
        </div>
    </div>

    <h4 class="fw-bold text-secondary mb-3"><i class="bi bi-cart-check"></i> Danh Sách Sản Phẩm</h4>
    <div class="table-responsive rounded shadow-sm border mb-4">
        <table class="table table-hover align-middle mb-0 bg-white">
            <thead class="table-light text-center">
                <tr>
                    <th>Hình Ảnh</th>
                    <th class="text-start">Tên Sản Phẩm</th>
                    <th>Đơn Giá</th>
                    <th>Số Lượng</th>
                    <th>Thành Tiền</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.OrderDetails != null && Model.OrderDetails.Any())
                {
                    foreach (var detail in Model.OrderDetails)
                    {
                        var subtotal = detail.Quantity * detail.Price;
                        <tr class="text-center">
                            <td>
                                @if (detail.Product != null && !string.IsNullOrEmpty(detail.Product.ImageUrl))
                                {
                                    <img src="@detail.Product.ImageUrl" alt="Product" style="width: 60px; height: 60px; object-fit: cover;" class="rounded shadow-sm border" />
                                }
                                else
                                {
                                    <div class="bg-light text-muted d-flex align-items-center justify-content-center rounded" style="width: 60px; height: 60px; margin: 0 auto;">
                                        <i class="bi bi-image"></i>
                                    </div>
                                }
                            </td>
                            <td class="text-start fw-bold">@(detail.Product != null ? detail.Product.Name : "Sản phẩm không tồn tại")</td>
                            <td>@detail.Price.ToString("#,##0") đ</td>
                            <td class="fw-bold fs-5">x @detail.Quantity</td>
                            <td class="text-danger fw-bold">@subtotal.ToString("#,##0") đ</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">Không tìm thấy chi tiết sản phẩm cho đơn hàng này.</td>
                    </tr>
                }
            </tbody>
            <tfoot class="table-light">
                <tr>
                    <td colspan="4" class="text-end fw-bold fs-5 pt-3">Tổng Cộng:</td>
                    <td class="text-center text-danger fw-bold fs-4 pt-3">@Model.TotalAmount.ToString("#,##0") VNĐ</td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>