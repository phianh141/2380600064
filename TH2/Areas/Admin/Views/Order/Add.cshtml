@model TH2.Models.Order
@{
    ViewData["Title"] = "Cập Nhật Đơn Hàng";
}

<style>
    body {
        background-image: url('/images/hinh-nen-may-tinh-4k-dep (66).jpg');
        background-size: cover;
        background-attachment: fixed;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }
</style>

<div class="container mt-5 mb-5 d-flex justify-content-center">
    <div class="col-md-8 col-lg-6 glass-card">
        <h2 class="text-warning text-center mb-4 fw-bold"><i class="bi bi-pencil-square"></i> Sửa Đơn Hàng #@Model.Id</h2>

        <form asp-action="Update" method="post">

            <div class="form-floating mb-3">
                <input asp-for="CustomerName" class="form-control" placeholder="Tên khách hàng" />
                <label asp-for="CustomerName">Tên khách hàng</label>
                <span asp-validation-for="CustomerName" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="PhoneNumber" class="form-control" placeholder="Số điện thoại" />
                <label asp-for="PhoneNumber">Số điện thoại</label>
                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <textarea asp-for="ShippingAddress" class="form-control" placeholder="Địa chỉ giao hàng" style="height: 100px"></textarea>
                <label asp-for="ShippingAddress">Địa chỉ giao hàng</label>
                <span asp-validation-for="ShippingAddress" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-4">
                <select asp-for="OrderStatus" class="form-select">
                    <option value="Pending">Chờ xử lý</option>
                    <option value="Shipping">Đang giao</option>
                    <option value="Completed">Hoàn thành</option>
                    <option value="Cancelled">Đã hủy</option>
                </select>
                <label asp-for="OrderStatus">Trạng thái đơn hàng</label>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-warning btn-lg shadow-sm fw-bold">Lưu Thay Đổi</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Hủy & Quay lại</a>
            </div>
        </form>
    </div>
</div>