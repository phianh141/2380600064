@model TH2.Models.Order
@{
    ViewData["Title"] = "Tạo Đơn Hàng Mới";
}

<style>
    :root {
        --dark-bg: #212529;
        --gold-accent: #e5c158;
    }

    .premium-card {
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
        padding: 40px;
        border-top: 4px solid var(--gold-accent);
    }

    /* Tùy chỉnh ô nhập liệu */
    .form-control, .form-select {
        border-radius: 8px;
        border: 1px solid #ced4da;
        padding: 0.75rem 1rem;
        font-size: 1.05rem;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--gold-accent);
            box-shadow: 0 0 0 0.25rem rgba(229, 193, 88, 0.25);
        }

    .btn-gold {
        background-color: var(--gold-accent);
        color: var(--dark-bg);
        font-weight: 700;
        transition: 0.3s;
        border: none;
    }

        .btn-gold:hover {
            background-color: var(--dark-bg);
            color: var(--gold-accent);
        }
</style>

<div class="container-fluid py-4 d-flex justify-content-center">
    <div class="col-md-8 col-lg-6 premium-card">
        <h2 class="text-center mb-4 fw-bold" style="color: var(--dark-bg); text-transform: uppercase; letter-spacing: 1px;">
            <i class="bi bi-plus-square-dotted me-2" style="color: var(--gold-accent);"></i>Tạo Đơn Hàng Mới
        </h2>

        <p class="text-center text-muted mb-4">Nhập thông tin khách hàng để tạo đơn đặt siêu xe</p>

        <form asp-action="Add" method="post">
            <div class="form-floating mb-3">
                <input asp-for="CustomerName" class="form-control" placeholder="Tên khách hàng" />
                <label asp-for="CustomerName" class="text-muted">Tên khách hàng</label>
                <span asp-validation-for="CustomerName" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="PhoneNumber" class="form-control" placeholder="Số điện thoại" />
                <label asp-for="PhoneNumber" class="text-muted">Số điện thoại</label>
                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <textarea asp-for="ShippingAddress" class="form-control" placeholder="Địa chỉ giao hàng" style="height: 120px"></textarea>
                <label asp-for="ShippingAddress" class="text-muted">Địa chỉ giao hàng</label>
                <span asp-validation-for="ShippingAddress" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-4">
                <select asp-for="OrderStatus" class="form-select">
                    <option value="Pending" selected>Chờ duyệt</option>
                    <option value="Shipping">Đang giao</option>
                    <option value="Completed">Hoàn thành</option>
                </select>
                <label asp-for="OrderStatus" class="text-muted">Trạng thái đơn hàng</label>
            </div>

            <div class="d-flex gap-3 mt-4">
                <button type="submit" class="btn btn-gold btn-lg w-100 rounded-pill shadow-sm">
                    <i class="bi bi-plus-circle me-2"></i>Tạo Đơn
                </button>
                <a asp-action="Index" class="btn btn-light border btn-lg w-100 rounded-pill text-dark fw-bold shadow-sm">
                    <i class="bi bi-x-circle me-2"></i>Hủy Bỏ
                </a>
            </div>
        </form>
    </div>
</div>