@model IEnumerable<TH2.Models.Order>

@{
    ViewData["Title"] = "Quản Lý Đơn Hàng";
}

<style>
    /* Biến màu sắc chuẩn Luxury */
    :root {
        --dark-bg: #212529;
        --gold-accent: #e5c158;
        --text-main: #333333;
    }

    /* Card tổng bọc viền vàng nhẹ */
    .premium-card {
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
        padding: 35px;
        border-top: 4px solid var(--gold-accent);
    }

    /* Header của bảng: Nền đen chữ vàng */
    .table-luxury {
        margin-bottom: 0;
        border-collapse: separate;
        border-spacing: 0 8px;
    }

        .table-luxury thead th {
            background-color: var(--dark-bg);
            color: var(--gold-accent);
            font-size: 1.1rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 18px;
            border: none;
        }

            .table-luxury thead th:first-child {
                border-top-left-radius: 8px;
                border-bottom-left-radius: 8px;
            }

            .table-luxury thead th:last-child {
                border-top-right-radius: 8px;
                border-bottom-right-radius: 8px;
            }

        /* Nội dung các dòng trong bảng */
        .table-luxury tbody tr {
            background-color: #fff;
            box-shadow: 0 2px 8px rgba(0,0,0,0.02);
            transition: all 0.3s ease;
        }

            .table-luxury tbody tr:hover {
                transform: scale(1.005);
                box-shadow: 0 5px 15px rgba(0,0,0,0.06);
                border-left: 3px solid var(--gold-accent);
            }

        .table-luxury td {
            padding: 20px 18px;
            vertical-align: middle;
            border-top: 1px solid #f0f0f0;
            border-bottom: 1px solid #f0f0f0;
            color: var(--text-main);
            font-size: 1.1rem;
        }

    /* Typography cho dữ liệu */
    .order-id {
        font-weight: 800;
        color: var(--dark-bg);
        font-size: 1.2rem;
    }

    .customer-name {
        font-weight: 600;
        color: #495057;
    }

    .order-price {
        color: #d90429;
        font-weight: 800;
        font-size: 1.25rem;
    }

    .order-date {
        color: #6c757d;
        font-size: 1.05rem;
    }

    /* Thẻ trạng thái bo tròn pastel */
    .status-badge {
        padding: 8px 16px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.95rem;
        display: inline-block;
    }

    .bg-pending {
        background-color: #fff3cd;
        color: #856404;
        border: 1px solid #ffeeba;
    }

    .bg-shipping {
        background-color: #e0f2fe;
        color: #0284c7;
        border: 1px solid #bae6fd;
    }

    .bg-completed {
        background-color: #d1e7dd;
        color: #0f5132;
        border: 1px solid #badbcc;
    }

    .bg-cancelled {
        background-color: #fee2e2;
        color: #dc2626;
        border: 1px solid #fecaca;
    }

    /* Các nút thao tác (Xem, Sửa, Xóa) */
    .action-btn {
        width: 42px;
        height: 42px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        margin: 0 5px;
        font-size: 1.2rem;
        transition: 0.3s;
        background: #f8f9fa;
        color: var(--dark-bg);
        border: 1px solid #dee2e6;
        text-decoration: none;
    }

        .action-btn:hover {
            background: var(--dark-bg);
            color: var(--gold-accent);
            border-color: var(--dark-bg);
        }

    .btn-del:hover {
        background: #d90429;
        color: #fff;
        border-color: #d90429;
    }
</style>

<div class="container-fluid py-4">
    <div class="premium-card">

        <div class="d-flex justify-content-between align-items-center mb-4 pb-2">
            <div>
                <h2 class="fw-bold mb-1" style="color: var(--dark-bg); text-transform: uppercase; letter-spacing: 1px;">
                    <i class="bi bi-receipt-cutoff me-2" style="color: var(--gold-accent);"></i>Danh Sách Đơn Hàng
                </h2>
                <p class="text-muted fs-5 mb-0">Theo dõi và xử lý các đơn đặt mua siêu xe</p>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-luxury align-middle text-center">
                <thead>
                    <tr>
                        <th style="width: 130px;">Mã Đơn</th>
                        <th>Thời Gian Đặt</th>
                        <th class="text-start">Khách Hàng</th>
                        <th>Tổng Giá Trị</th>
                        <th>Trạng Thái</th>
                        <th style="width: 180px;">Tùy Chọn</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <span class="order-id">#@item.Id</span>
                                </td>

                                <td>
                                    <div class="order-date">
                                        <i class="bi bi-clock me-1"></i> @item.OrderDate.ToString("dd/MM/yyyy")
                                        <br />
                                        <small class="text-muted">@item.OrderDate.ToString("HH:mm")</small>
                                    </div>
                                </td>

                                <td class="text-start">
                                    <div class="customer-name">@item.CustomerName</div>
                                </td>

                                <td>
                                    <div class="order-price">@item.TotalAmount.ToString("#,##0") ₫</div>
                                </td>

                                <td>
                                    @if (item.OrderStatus == "Pending")
                                    {
                                        <span class="status-badge bg-pending"><i class="bi bi-hourglass-split me-1"></i> Chờ duyệt</span>
                                    }
                                    else if (item.OrderStatus == "Shipping")
                                    {
                                        <span class="status-badge bg-shipping"><i class="bi bi-truck me-1"></i> Đang giao</span>
                                    }
                                    else if (item.OrderStatus == "Completed")
                                    {
                                        <span class="status-badge bg-completed"><i class="bi bi-check-circle-fill me-1"></i> Hoàn thành</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge bg-cancelled"><i class="bi bi-x-circle-fill me-1"></i> Đã hủy</span>
                                    }
                                </td>

                                <td>
                                    <a asp-action="Display" asp-route-id="@item.Id" class="action-btn" title="Xem chi tiết đơn">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Update" asp-route-id="@item.Id" class="action-btn" title="Cập nhật trạng thái">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="action-btn btn-del" title="Xóa đơn hàng">
                                        <i class="bi bi-trash3"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <div class="py-4">
                                    <i class="bi bi-clipboard-x text-muted" style="font-size: 4rem;"></i>
                                    <h4 class="mt-4 fw-bold" style="color: var(--dark-bg);">Chưa có đơn hàng nào</h4>
                                    <p class="text-muted fs-5">Các đơn đặt xe mới sẽ hiển thị tại đây.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>