@{
    ViewData["Title"] = "Dashboard Tổng Quan";
}

<style>
    /* Hiệu ứng trượt lên nhẹ nhàng khi di chuột vào Card */
    .stat-card {
        border: none;
        border-radius: 16px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        overflow: hidden;
    }

        .stat-card:hover {
            transform: translateY(-7px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.15) !important;
        }

    /* Hộp biểu tượng Icon */
    .icon-box {
        width: 65px;
        height: 65px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.2rem;
    }

    /* Màu Gradient cực đẹp cho siêu xe */
    .bg-gradient-primary {
        background: linear-gradient(135deg, #4e73df 0%, #224abe 100%);
    }

    .bg-gradient-success {
        background: linear-gradient(135deg, #1cc88a 0%, #13855f 100%);
    }

    .bg-gradient-warning {
        background: linear-gradient(135deg, #f6c23e 0%, #dda20a 100%);
    }
</style>

<div class="row mb-5">
    <div class="col-xl-4 col-md-6 mb-4">
        <div class="card stat-card shadow-sm h-100 py-3 bg-gradient-primary text-white">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col mr-2">
                        <div class="text-sm font-weight-bold text-uppercase mb-1 opacity-75">Kho Siêu Xe</div>
                        <div class="h2 mb-0 font-weight-bold">120 <span class="fs-6 fw-normal">chiếc</span></div>
                    </div>
                    <div class="col-auto">
                        <div class="icon-box bg-white text-primary shadow-sm">
                            <i class="bi bi-car-front-fill"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4 col-md-6 mb-4">
        <div class="card stat-card shadow-sm h-100 py-3 bg-gradient-success text-white">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col mr-2">
                        <div class="text-sm font-weight-bold text-uppercase mb-1 opacity-75">Đơn Đặt Hàng</div>
                        <div class="h2 mb-0 font-weight-bold">15 <span class="fs-6 fw-normal">đơn</span></div>
                    </div>
                    <div class="col-auto">
                        <div class="icon-box bg-white text-success shadow-sm">
                            <i class="bi bi-clipboard-check-fill"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4 col-md-6 mb-4">
        <div class="card stat-card shadow-sm h-100 py-3 bg-gradient-warning text-dark">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col mr-2">
                        <div class="text-sm font-weight-bold text-uppercase mb-1 opacity-75">Doanh Thu Tạm Tính</div>
                        <div class="h2 mb-0 font-weight-bold">550 <span class="fs-6 fw-normal">Tỷ VNĐ</span></div>
                    </div>
                    <div class="col-auto">
                        <div class="icon-box bg-white text-warning shadow-sm">
                            <i class="bi bi-cash-coin"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-header py-3 bg-white border-bottom rounded-top-4 d-flex justify-content-between align-items-center">
        <h6 class="m-0 fw-bold text-primary"><i class="bi bi-clock-history me-2"></i>Đơn đặt xe mới nhất</h6>
        <button class="btn btn-sm btn-outline-secondary">Xem tất cả</button>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted">
                    <tr>
                        <th class="ps-4">Mã Đơn</th>
                        <th>Khách Hàng</th>
                        <th>Siêu Xe</th>
                        <th>Tổng Tiền</th>
                        <th>Trạng Thái</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="ps-4 fw-bold">#DH001</td>
                        <td>Nguyễn Văn A</td>
                        <td>Lamborghini Aventador SVJ</td>
                        <td class="text-danger fw-bold">25 Tỷ</td>
                        <td><span class="badge bg-warning text-dark px-3 py-2 rounded-pill">Chờ duyệt</span></td>
                    </tr>
                    <tr>
                        <td class="ps-4 fw-bold">#DH002</td>
                        <td>Trần Thị B</td>
                        <td>Ferrari SF90 Stradale</td>
                        <td class="text-danger fw-bold">30 Tỷ</td>
                        <td><span class="badge bg-success px-3 py-2 rounded-pill">Đã giao</span></td>
                    </tr>
                    <tr>
                        <td class="ps-4 fw-bold">#DH003</td>
                        <td>Lê Văn C</td>
                        <td>McLaren 720S</td>
                        <td class="text-danger fw-bold">18 Tỷ</td>
                        <td><span class="badge bg-info text-dark px-3 py-2 rounded-pill">Đang vận chuyển</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>