@model TH2.Models.Product
@{
    ViewData["Title"] = "Cập Nhật Sản Phẩm";
}

<style>
    body {
        background-image: url('/images/mclaren-765lt-night-3840x2563-20401.jpg');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
    }

    .form-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }
</style>

<div class="container mt-5 mb-5 d-flex justify-content-center">
    <div class="col-md-8 col-lg-6 form-card">
        <h2 class="text-warning text-center mb-4 fw-bold">✏️ Cập Nhật Sản Phẩm</h2>

        <form asp-action="Update" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />

            <div class="form-floating mb-3">
                <input asp-for="Name" class="form-control" placeholder="Tên sản phẩm" />
                <label asp-for="Name">Tên sản phẩm</label>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Price" class="form-control" placeholder="Giá" />
                <label asp-for="Price">Giá (VNĐ)</label>
                <span asp-validation-for="Price" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <textarea asp-for="Description" class="form-control" placeholder="Mô tả" style="height: 100px"></textarea>
                <label asp-for="Description">Mô tả sản phẩm</label>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select"></select>
                <label asp-for="CategoryId">Danh mục sản phẩm</label>
            </div>

            <hr class="my-4" />

            <div class="form-group mb-3">
                <label class="fw-bold mb-2">Thay đổi ảnh đại diện:</label>
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mb-2">
                        <img src="@Model.ImageUrl" alt="Ảnh hiện tại" style="width: 100px; height: 100px; object-fit: cover;" class="rounded shadow-sm" />
                    </div>
                }
                <input type="file" name="imageUrl" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label class="fw-bold mb-2">Thêm ảnh phụ mới:</label>
                <input type="file" name="imageUrls" class="form-control" multiple />
            </div>

            @if (Model.Images != null && Model.Images.Any())
            {
                <div class="form-group mb-4">
                    <label class="fw-bold mb-2 text-danger">Đánh dấu để xóa ảnh phụ cũ:</label>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var img in Model.Images)
                        {
                            <div class="card p-1 shadow-sm border-danger" style="width: 120px;">
                                <img src="@img.Url" style="width: 100%; height: 90px; object-fit: cover;" class="rounded" />
                                <div class="form-check mt-2 d-flex justify-content-center">
                                    <input class="form-check-input" type="checkbox" name="deleteImageIds" value="@img.Id" id="del_@img.Id">
                                    <label class="form-check-label ms-1 small" for="del_@img.Id">Xóa</label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="d-grid gap-2 mt-4">
                <button type="submit" class="btn btn-warning btn-lg shadow-sm text-dark fw-bold">Lưu Thay Đổi</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Hủy & Quay lại</a>
            </div>
        </form>
    </div>
</div>