@model TH2.Models.Product
@{
    ViewData["Title"] = "Cập Nhật Sản Phẩm";
}

<style>
    :root {
        --dark-bg: #212529;
        --gold-accent: #e5c158;
    }

    .premium-card {
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
        padding: 40px;
        border-top: 4px solid var(--gold-accent);
    }

    .form-control, .form-select {
        border-radius: 8px;
        border: 1px solid #ced4da;
        padding: 0.75rem 1rem;
        font-size: 1.05rem;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--gold-accent);
            box-shadow: 0 0 0 0.25rem rgba(229, 193, 88, 0.25);
        }

    .btn-gold {
        background-color: var(--gold-accent);
        color: var(--dark-bg);
        font-weight: 700;
        transition: 0.3s;
        border: none;
    }

        .btn-gold:hover {
            background-color: var(--dark-bg);
            color: var(--gold-accent);
        }

    .img-preview {
        width: 100px;
        height: 100px;
        object-fit: cover;
        border-radius: 8px;
        border: 2px solid #f0f0f0;
    }
</style>

<div class="container-fluid py-4 d-flex justify-content-center">
    <div class="col-md-8 col-lg-6 premium-card">
        <h2 class="text-center mb-4 fw-bold" style="color: var(--dark-bg); text-transform: uppercase; letter-spacing: 1px;">
            <i class="bi bi-pencil-square me-2" style="color: var(--gold-accent);"></i>Chỉnh Sửa Thông Tin Xe
        </h2>

        <form asp-action="Update" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />

            <div class="form-floating mb-3">
                <input asp-for="Name" class="form-control" placeholder="Tên sản phẩm" />
                <label asp-for="Name" class="text-muted">Tên siêu xe</label>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Price" class="form-control" placeholder="Giá" />
                <label asp-for="Price" class="text-muted">Giá bán (VNĐ)</label>
                <span asp-validation-for="Price" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <textarea asp-for="Description" class="form-control" placeholder="Mô tả" style="height: 120px"></textarea>
                <label asp-for="Description" class="text-muted">Mô tả thông số kỹ thuật</label>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select"></select>
                <label asp-for="CategoryId" class="text-muted">Danh mục xe</label>
            </div>

            <div class="p-3 bg-light rounded border mb-3">
                <label class="fw-bold mb-2 text-dark d-block">Cập nhật ảnh đại diện:</label>
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mb-3">
                        <img src="@Model.ImageUrl" alt="Ảnh hiện tại" class="img-preview shadow-sm" />
                    </div>
                }
                <input type="file" name="imageUrl" class="form-control bg-white" />
            </div>

            <div class="p-3 bg-light rounded border mb-4">
                <label class="fw-bold mb-2 text-dark d-block">Thêm ảnh phụ mới:</label>
                <input type="file" name="imageUrls" class="form-control bg-white mb-3" multiple />

                @if (Model.Images != null && Model.Images.Any())
                {
                    <label class="fw-bold mb-2 text-danger"><i class="bi bi-trash me-1"></i>Chọn để xóa ảnh phụ cũ:</label>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var img in Model.Images)
                        {
                            <div class="position-relative">
                                <img src="@img.Url" class="img-preview shadow-sm" style="width: 80px; height: 80px;" />
                                <div class="form-check position-absolute top-0 end-0 bg-white rounded-circle shadow-sm m-1 p-0" style="width: 24px; height: 24px; display: flex; align-items: center; justify-content: center;">
                                    <input class="form-check-input m-0" type="checkbox" name="deleteImageIds" value="@img.Id" id="del_@img.Id" style="cursor: pointer;">
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="d-flex gap-3 mt-4">
                <button type="submit" class="btn btn-gold btn-lg w-100 rounded-pill shadow-sm">
                    <i class="bi bi-save me-2"></i>Lưu Thay Đổi
                </button>
                <a asp-action="Index" class="btn btn-light border btn-lg w-100 rounded-pill text-dark fw-bold shadow-sm">
                    <i class="bi bi-x-circle me-2"></i>Hủy Bỏ
                </a>
            </div>
        </form>
    </div>
</div>