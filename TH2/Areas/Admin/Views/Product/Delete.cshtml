@model TH2.Models.Product
@{
    ViewData["Title"] = "Xóa Sản Phẩm";
}

<style>
    :root {
        --dark-bg: #212529;
    }

    .danger-card {
        background: #ffffff;
        border-radius: 12px;
        padding: 40px;
        border-top: 5px solid #d90429;
        box-shadow: 0 15px 35px rgba(217, 4, 41, 0.1);
    }

    .info-box {
        background-color: #f8f9fa;
        border: 1px solid #f0f0f0;
        border-radius: 8px;
        padding: 20px;
    }

    .img-thumb {
        width: 80px;
        height: 80px;
        object-fit: cover;
        border-radius: 6px;
        border: 2px solid #fff;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
</style>

<div class="container-fluid py-5 d-flex justify-content-center">
    <div class="col-md-8 col-lg-6 danger-card text-center">

        <div class="mb-4">
            <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 4.5rem; filter: drop-shadow(0 4px 6px rgba(217, 4, 41, 0.3));"></i>
        </div>

        <h2 class="text-danger mb-3 fw-bold" style="text-transform: uppercase; letter-spacing: 1px;">Xác Nhận Xóa Siêu Xe</h2>
        <p class="fs-5 text-muted mb-4">Bạn có chắc chắn muốn xóa vĩnh viễn <strong class="text-dark">@Model.Name</strong> khỏi kho không?</p>

        <div class="info-box mb-4 text-start">
            <p class="mb-2 fs-5"><strong>Giá bán:</strong> <span class="text-danger fw-bold">@Model.Price.ToString("#,##0") VNĐ</span></p>
            <p class="mb-3"><strong>Mô tả:</strong> <span class="text-muted">@Model.Description</span></p>

            <hr class="text-muted opacity-25" />

            <p class="mb-2 fw-bold text-dark">Ảnh lưu trữ:</p>
            <div class="d-flex flex-wrap gap-2 justify-content-start">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" class="img-thumb" title="Ảnh đại diện" />
                }
                @if (Model.Images != null && Model.Images.Any())
                {
                    foreach (var img in Model.Images)
                    {
                        <img src="@img.Url" class="img-thumb" title="Ảnh phụ" />
                    }
                }
            </div>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex justify-content-center gap-3">
                <button type="submit" class="btn btn-danger btn-lg px-5 rounded-pill shadow-sm fw-bold">
                    <i class="bi bi-trash3 me-2"></i>Có, Xóa Ngay
                </button>
                <a asp-action="Index" class="btn btn-light border btn-lg px-5 rounded-pill text-dark shadow-sm fw-bold">
                    <i class="bi bi-arrow-return-left me-2"></i>Quay Lại
                </a>
            </div>
        </form>

    </div>
</div>