@model TH2.Models.Product
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Thêm Sản Phẩm";
}

<style>
    :root {
        --dark-bg: #212529;
        --gold-accent: #e5c158;
    }

    .premium-card {
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
        padding: 40px;
        border-top: 4px solid var(--gold-accent);
    }

    .form-control, .form-select {
        border-radius: 8px;
        border: 1px solid #ced4da;
        padding: 0.75rem 1rem;
        font-size: 1.05rem;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--gold-accent);
            box-shadow: 0 0 0 0.25rem rgba(229, 193, 88, 0.25);
        }

    .btn-gold {
        background-color: var(--gold-accent);
        color: var(--dark-bg);
        font-weight: 700;
        transition: 0.3s;
        border: none;
    }

        .btn-gold:hover {
            background-color: var(--dark-bg);
            color: var(--gold-accent);
        }
</style>

<div class="container-fluid py-4 d-flex justify-content-center">
    <div class="col-md-8 col-lg-6 premium-card">
        <h2 class="text-center mb-4 fw-bold" style="color: var(--dark-bg); text-transform: uppercase; letter-spacing: 1px;">
            <i class="bi bi-car-front-fill me-2" style="color: var(--gold-accent);"></i>Nhập Xe Mới
        </h2>

        <form asp-action="Add" enctype="multipart/form-data">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="form-floating mb-3">
                <input asp-for="Name" class="form-control" placeholder="Tên sản phẩm" />
                <label asp-for="Name" class="text-muted">Tên siêu xe</label>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Price" class="form-control" placeholder="Giá" />
                <label asp-for="Price" class="text-muted">Giá bán (VNĐ)</label>
                <span asp-validation-for="Price" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <textarea asp-for="Description" class="form-control" placeholder="Mô tả" style="height: 120px"></textarea>
                <label asp-for="Description" class="text-muted">Mô tả thông số kỹ thuật</label>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CategoryId" class="fw-bold mb-2 text-dark">Danh mục xe</label>
                <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ImageUrl" class="fw-bold mb-2 text-dark">Ảnh đại diện (Thumbnail)</label>
                <input type="file" asp-for="ImageUrl" class="form-control" accept="image/*" />
            </div>

            <div class="form-group mb-4">
                <label class="fw-bold mb-2 text-dark">Các góc chụp khác (Gallery)</label>
                <input type="file" name="imageUrls" multiple class="form-control" accept="image/*" />
            </div>

            <div class="d-flex gap-3 mt-4">
                <button type="submit" class="btn btn-gold btn-lg w-100 rounded-pill shadow-sm">
                    <i class="bi bi-cloud-arrow-up-fill me-2"></i>Lưu Sản Phẩm
                </button>
                <a asp-action="Index" class="btn btn-light border btn-lg w-100 rounded-pill text-dark fw-bold shadow-sm">
                    <i class="bi bi-x-circle me-2"></i>Hủy Bỏ
                </a>
            </div>
        </form>
    </div>
</div>