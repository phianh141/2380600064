@model TH2.Models.Product
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Thêm Sản Phẩm";
}

<style>
    body {

        background-image: url('/images/mclaren-765lt-night-3840x2563-20401.jpg');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
    }

    .form-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }
</style>

<div class="container mt-5 mb-5 d-flex justify-content-center">
    <div class="col-md-8 col-lg-6 form-card">
        <h2 class="text-primary text-center mb-4 fw-bold">✨ Thêm Sản Phẩm Mới</h2>

        <form asp-action="Add" enctype="multipart/form-data">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="form-floating mb-3">
                <input asp-for="Name" class="form-control" placeholder="Tên sản phẩm" />
                <label asp-for="Name">Tên sản phẩm</label>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Price" class="form-control" placeholder="Giá" />
                <label asp-for="Price">Giá (VNĐ)</label>
                <span asp-validation-for="Price" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <textarea asp-for="Description" class="form-control" placeholder="Mô tả" style="height: 100px"></textarea>
                <label asp-for="Description">Mô tả sản phẩm</label>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CategoryId" class="fw-bold mb-1">Danh mục</label>
                <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ImageUrl" class="fw-bold mb-1">Ảnh đại diện</label>
                <input type="file" asp-for="ImageUrl" class="form-control" accept="image/*" />
            </div>

            <div class="form-group mb-4">
                <label class="fw-bold mb-1">Các ảnh khác</label>
                <input type="file" name="imageUrls" multiple class="form-control" accept="image/*" />
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary btn-lg shadow-sm">Thêm Sản Phẩm</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Hủy & Quay lại</a>
            </div>
        </form>
    </div>
</div>