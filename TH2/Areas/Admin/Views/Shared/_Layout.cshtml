<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Quản Lý Siêu Xe</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        /* Biến màu sắc Luxury */
        :root {
            --sidebar-width: 270px;
            --gold-accent: #e5c158;
            --dark-bg: #15171a; /* Đen nhám sâu hơn */
            --darker-bg: #0e0f11;
            --text-muted-custom: #8a949f;
        }

        body {
            background-color: #f4f6f9;
            overflow-x: hidden;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* -------------------------
                   THIẾT KẾ SIDEBAR (MENU)
                ------------------------- */
        .sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            background: var(--dark-bg);
            color: #fff;
            z-index: 1000;
            box-shadow: 4px 0 15px rgba(0,0,0,0.05);
            border-right: 1px solid #222;
        }

            .sidebar .brand {
                height: 75px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.35rem;
                font-weight: 800;
                letter-spacing: 2px;
                border-bottom: 1px solid #25282d;
                background: var(--darker-bg);
                color: #fff;
                text-decoration: none;
                text-transform: uppercase;
            }

            .sidebar .nav-column {
                padding-top: 15px;
            }

            .sidebar .nav-link {
                color: var(--text-muted-custom);
                padding: 14px 25px;
                font-weight: 500;
                font-size: 1.05rem;
                transition: all 0.3s ease;
                display: flex;
                align-items: center;
                border-left: 4px solid transparent; /* Chuẩn bị cho viền vàng khi active */
                margin-bottom: 4px;
            }

                /* Hiệu ứng di chuột (Hover) */
                .sidebar .nav-link:hover {
                    color: #fff;
                    background: rgba(255, 255, 255, 0.03);
                }

                /* Hiệu ứng đang chọn (Active) */
                .sidebar .nav-link.active {
                    color: var(--gold-accent);
                    border-left-color: var(--gold-accent);
                    background: linear-gradient(90deg, rgba(229, 193, 88, 0.08) 0%, transparent 100%);
                    font-weight: 600;
                }

                .sidebar .nav-link i {
                    font-size: 1.3rem;
                    margin-right: 15px;
                    width: 24px;
                    text-align: center;
                }

        /* -------------------------
                   KHUNG NỘI DUNG CHÍNH
                ------------------------- */
        .main-content {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Thanh Header trên cùng */
        .top-navbar {
            height: 75px;
            background: #ffffff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 35px;
            box-shadow: 0 2px 15px rgba(0,0,0,0.03);
            z-index: 999;
            position: sticky;
            top: 0;
            border-bottom: 1px solid #f0f0f0;
        }

        /* Nút quay về trang chủ phong cách Premium */
        .btn-luxury-outline {
            color: var(--dark-bg);
            border: 2px solid var(--gold-accent);
            background-color: transparent;
            font-weight: 600;
            transition: 0.3s;
        }

            .btn-luxury-outline:hover {
                background-color: var(--gold-accent);
                color: var(--dark-bg);
                box-shadow: 0 4px 10px rgba(229, 193, 88, 0.3);
            }

        .content-wrapper {
            padding: 30px 35px;
            flex: 1;
        }
    </style>
</head>
<body>
    <nav class="sidebar">
        <a href="#" class="brand">
            <i class="bi bi-car-front-fill me-2" style="color: var(--gold-accent);"></i>ADMIN SYSTEM
        </a>

        @{
            
            var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        }

        <div class="nav-column">
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Home" ? "active" : "")" asp-area="Admin" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-grid-1x2-fill"></i> Tổng quan
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Category" ? "active" : "")" asp-area="Admin" asp-controller="Category" asp-action="Index">
                        <i class="bi bi-tags-fill"></i> Danh mục xe
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Product" ? "active" : "")" asp-area="Admin" asp-controller="Product" asp-action="Index">
                        <i class="bi bi-car-front-fill"></i> Quản lý Sản phẩm
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Order" ? "active" : "")" asp-area="Admin" asp-controller="Order" asp-action="Index">
                        <i class="bi bi-cart-check-fill"></i> Đơn đặt hàng
                    </a>
                </li>
            </ul>
        </div>
    </nav>

    <div class="main-content">

        <header class="top-navbar">
            <div>
                <h4 class="mb-0 text-dark fw-bold" style="letter-spacing: 0.5px;">@ViewData["Title"]</h4>
            </div>
            <div class="d-flex align-items-center">
                <a href="/" class="btn btn-luxury-outline rounded-pill px-4 py-2 shadow-sm d-flex align-items-center">
                    <i class="bi bi-globe me-2 fs-5"></i> Trải nghiệm Web
                </a>
            </div>
        </header>

        <div class="content-wrapper">
            @RenderBody()
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>